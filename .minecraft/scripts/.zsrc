ible.\n\nYou can also follow development on my Twitter, if that\u0027s your thing: https://twitter.com/jellysquid_","url":"https://minecraft.curseforge.com/projects/phosphor-forge","version":"1.12.2-0.2.7-SNAPSHOT","authorList":["Angeline (@jellysquid)"],"credits":"","requiredMods":[],"dependencies":[{"label":"neid","version":"unknown","range":"[1.5.4.4,)"},{"label":"spongeforge","version":"unknown","range":"[1.12.2-2838-7.1.7-RC3844,)"}],"dependants":[]},{"modid":"placebo","name":"Placebo","description":"1 library boi","url":"","version":"1.12.2-1.6.0","authorList":["Shadows_of_Fire"],"credits":"","requiredMods":[],"dependencies":[],"dependants":[]},{"modid":"probe","name":"Probe","description":"Dump information to .zsrc file for future use.","url":"https://github.com/Yesterday17/Probe","version":"0.1.24","authorList":["Yesterday17"],"credits":"","requiredMods":[{"label":"crafttweaker","version":"unknown","range":"any"},{"label":"jei","version":"unknown","range":"any"}],"dependencies":[{"label":"crafttweaker","version":"unknown","range":"any"},{"label":"jei","version":"unknown","range":"any"}],"dependants":[]},{"modid":"pyrotech","name":"Pyrotech","description":"Fire it up.","url":"","version":"1.12.2-1.5.25","authorList":["codetaylor"],"credits":"","requiredMods":[{"label":"athenaeum","version":"unknown","range":"[1.12.2-1.19.5,)"},{"label":"dropt","version":"unknown","range":"[1.12.2-1.12.0,)"}],"dependencies":[{"label":"dropt","version":"unknown","range":"[1.12.2-1.12.0,)"},{"label":"athenaeum","version":"unknown","range":"[1.12.2-1.19.5,)"},{"label":"patchouli","version":"unknown","range":"any"},{"label":"crafttweaker","version":"unknown","range":"any"},{"label":"jei","version":"unknown","range":"any"},{"label":"gamestages","version":"unknown","range":"any"},{"label":"thermalexpansion","version":"unknown","range":"any"},{"label":"theoneprobe","version":"unknown","range":"any"},{"label":"waila","version":"unknown","range":"any"}],"dependants":[]},{"modid":"rando